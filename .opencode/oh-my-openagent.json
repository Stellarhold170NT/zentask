{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "hooks": {
    "todo-continuation-enforcer": {
      "enabled": true,
      "strategy": "planning-folder",
      "auto_resume": true
    },
    "comment-checker": {
      "enabled": true,
      "severity": "warn",
      "check_on_commit": true
    },
    "think-mode": {
      "enabled": true,
      "min_tokens": 512
    }
  },
  "disabled_hooks": [
    "startup-toast"
  ],
  "mcp": {
    "stitch": {
      "type": "local",
      "command": [
        "npx",
        "@_davideast/stitch-mcp",
        "proxy"
      ],
      "environment": {
        "STITCH_API_KEY": "${STITCH_API_KEY}"
      }
    }
  },
  "agents": {
    "sisyphus": {
      "model": "opencode-go/kimi-k2.6"
    },
    "oracle": {
      "model": "opencode-go/glm-5.1"
    },
    "librarian": {
      "model": "opencode-go/minimax-m2.7",
      "fallback_models": [
        {
          "model": "opencode-go/qwen3.6-plus"
        }
      ]
    },
    "explore": {
      "model": "opencode-go/minimax-m2.7",
      "fallback_models": [
        {
          "model": "opencode-go/qwen3.6-plus"
        }
      ]
    },
    "multimodal-looker": {
      "model": "opencode-go/kimi-k2.6"
    },
    "prometheus": {
      "model": "opencode-go/glm-5.1"
    },
    "metis": {
      "model": "opencode-go/glm-5.1"
    },
    "momus": {
      "model": "opencode-go/glm-5.1"
    },
    "atlas": {
      "model": "opencode-go/kimi-k2.6"
    },
    "sisyphus-junior": {
      "model": "opencode-go/qwen3.6-plus"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "opencode-go/glm-5.1"
    },
    "ultrabrain": {
      "model": "opencode-go/glm-5.1"
    },
    "deep": {
      "model": "opencode-go/deepseek-v4-pro"
    },
    "quick": {
      "model": "opencode-go/minimax-m2.7"
    },
    "unspecified-low": {
      "model": "opencode-go/qwen3.6-plus"
    },
    "unspecified-high": {
      "model": "opencode-go/kimi-k2.6"
    },
    "writing": {
      "model": "opencode-go/kimi-k2.6"
    }
  }
}